# Copy this to .env and fill in your keys.
# Primary model runs on Groq; fallback runs on Google AI Studio (Gemini).
# Both free tiers — the fallback exists specifically to ride out Groq's
# per-minute and per-day rate-limit caps.

# Groq free tier: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google AI Studio free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
