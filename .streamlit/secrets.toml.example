# Streamlit Community Cloud secrets template.
#
# On Streamlit Cloud, paste the contents of this file into
#   Advanced settings → Secrets
# of the app — do NOT commit a real secrets.toml to the repo.
#
# For local development, keep your key in .env instead; st.secrets is only
# consulted when the file exists.

GROQ_API_KEY = "your_free_groq_key_here"
GEMINI_API_KEY = "your_free_gemini_key_here"